{
  "name": "repo-atlas",
  "version": "0.1.0",
  "description": "Incremental, agent-friendly codebase atlas: per-path descriptions with git-hash staleness tracking and a self-contained HTML viewer.",
  "type": "module",
  "bin": {
    "repo-atlas": "./src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "picomatch": "^4.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "scripts": {
    "build:viewer": "esbuild viewer/main.jsx --bundle --minify --jsx=automatic --outfile=src/vendor/viewer.js",
    "dev:viewer": "esbuild viewer/main.jsx --bundle --jsx=automatic --outfile=src/vendor/viewer.js --watch"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
